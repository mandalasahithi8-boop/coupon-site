# Copy this file to .env and fill in real values. .env is gitignored.

# Groq API key for AI-powered coupon recommendations.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Flask secret key - used to sign sessions/cookies.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Which config to load: development | production | testing
FLASK_ENV=development

# Secret token required to call POST /admin/refresh (header: X-Admin-Token).
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(24))"
ADMIN_REFRESH_TOKEN=change-this-to-a-random-token

# Optional - persistent Postgres URL (e.g. Render Postgres). Defaults to local SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional - comma-separated RSS feed URLs, overrides the built-in default list
# (Slickdeals frontpage, Slickdeals pop deals, Brad's Deals, Dealsplus, r/deals, r/coupons).
# RSS_FEED_URLS=https://slickdeals.net/newsearch.php?mode=frontpage&frontpage=1&rss=1,https://slickdeals.net/newsearch.php?mode=popdeals&rss=1,https://www.bradsdeals.com/feed,https://www.dealsplus.com/feed,https://www.reddit.com/r/deals/.rss,https://www.reddit.com/r/coupons/.rss

# Set to "false" to disable the background scheduler (daily fetch, expiry, cleanup jobs).
SCHEDULER_ENABLED=true
